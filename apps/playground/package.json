{
  "name": "@mumukji/playground",
  "private": true,
  "type": "module",
  "description": "Next.js playground for testing the built @mumukji/ui package as a real consumer.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@mumukji/tokens": "workspace:*",
    "@mumukji/ui": "workspace:*",
    "next": "^15.5.19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
