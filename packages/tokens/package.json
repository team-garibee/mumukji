{
  "name": "@mumukji/tokens",
  "version": "0.1.0",
  "description": "Design tokens for Mumukji design system. Includes colors, typography, spacing, and other foundational styles.",
  "author": "team-garibee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/team-garibee/mumukji-ui.git",
    "directory": "packages/tokens"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./css": {
      "types": "./dist/css/primitive.css.d.ts",
      "default": "./dist/css/primitive.css"
    }
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "tokens",
    "mumukji"
  ],
  "scripts": {
    "generate:tokens": "node scripts/generateTokens.js",
    "typecheck": "tsc --noEmit",
    "build": "pnpm generate:tokens",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.2.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cssnano": "^7.1.4",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
